# ── Telegram listener (your personal account — get from my.telegram.org) ─────
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_PHONE=+1234567890

# ── Telegram control bot (token from @BotFather) ──────────────────────────────
TELEGRAM_CONTROL_BOT_TOKEN=
TELEGRAM_CHAT_ID=              # send /start to @userinfobot to get your chat ID

# ── Solana ────────────────────────────────────────────────────────────────────
SOLANA_RPC_URL=                # Helius free tier: https://mainnet.helius-rpc.com/?api-key=...
JITO_RPC_URL=https://mainnet.block-engine.jito.wtf/api/v1
WALLET_PRIVATE_KEY=            # base58 encoded — use a fresh hot wallet only

# ── Trading parameters ────────────────────────────────────────────────────────
MAX_POSITION_PCT=0.05
MAX_CONCURRENT_POSITIONS=3
DAILY_LOSS_LIMIT_PCT=0.20
TIME_SL_HOURS=2

# ── Channels to monitor (comma-separated @usernames or numeric channel IDs) ───
SIGNAL_CHANNELS=@channel1,@channel2

# ── Safety switches — keep both true until Phase 9 ────────────────────────────
DRY_RUN=true          # true = no real swaps ever submitted
PAPER_TRADE=true      # true = log intended trades, don't call executor

# ── Signal filtering ──────────────────────────────────────────────────────────
MIN_CONVICTION=6      # signals below this score are discarded (1-10)
